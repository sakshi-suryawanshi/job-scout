# ── Required ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── AI scoring + resume tailoring (Gemini) ───────────────────────────────────
# Free: 1500 req/day — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Company/job discovery via Google dorking ─────────────────────────────────
# Free: 2500 searches/month — https://serper.dev
SERPER_API_KEY=your_serper_api_key

# ── Daily email digest ────────────────────────────────────────────────────────
# Gmail address used to SEND the digest
GMAIL_USER=you@gmail.com
# 16-char app password: Google Account → Security → 2FA → App passwords
GMAIL_APP_PASS=xxxx_xxxx_xxxx_xxxx
# Where to receive the digest (can be the same as GMAIL_USER)
DIGEST_EMAIL=you@gmail.com

# ── Auto-apply (Playwright form-fill) ────────────────────────────────────────
# These fill in application forms for Greenhouse / Lever / Ashby automatically.
# NEVER stored in the database — read from env only.
APPLY_EMAIL=you@gmail.com
APPLY_FIRST_NAME=Jane
APPLY_LAST_NAME=Doe
APPLY_PHONE=+1-555-000-0000
APPLY_LINKEDIN=https://linkedin.com/in/your-profile
APPLY_GITHUB=https://github.com/your-username
APPLY_PORTFOLIO=https://yoursite.com
APPLY_LOCATION=Remote

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to 'true' to use mock API responses (no real API keys needed).
# Useful for demos, screenshots, and local dev without burning quota.
DEMO_MODE=false
